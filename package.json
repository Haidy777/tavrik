{
  "name": "tavrik",
  "private": true,
  "version": "0.6.0",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:ui": "pnpm --filter @tavrik/ui dev",
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @tavrik/ui build",
    "preview:ui": "pnpm --filter @tavrik/ui preview",
    "lint": "biome check",
    "lint:fix": "biome check . --write",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:database": "vitest run --project database",
    "test:watch": "vitest",
    "types-check": "tsc --pretty --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "dev:db": "docker compose -f docker/compose.dev.yml up -d --wait postgres && pnpm run db:codegen",
    "dev:db:down": "docker compose -f docker/compose.dev.yml down",
    "dev:telegram": "docker compose -f docker/compose.dev.yml up telegram",
    "db:codegen": "pnpm --filter @tavrik/lib db:codegen",
    "db:regen": "pnpm run dev:db && pnpm run test:database && pnpm --filter @tavrik/lib db:migrate:down && pnpm run dev:db:down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "2.31.0",
    "@types/pg": "8.20.0",
    "husky": "9.1.7",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "vitest": "4.1.5"
  },
  "dependencies": {}
}
